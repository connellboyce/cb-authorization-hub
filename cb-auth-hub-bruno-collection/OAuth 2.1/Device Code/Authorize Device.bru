meta {
  name: Authorize Device
  type: http
  seq: 1
}

post {
  url: {{oauth.base-url}}/oauth2/device_authorization
  body: formUrlEncoded
  auth: inherit
}

body:form-urlencoded {
  client_id: {{oauth.client-id}}
  client_secret: {{oauth.client-secret}}
  scope: openid
}

settings {
  encodeUrl: true
  timeout: 0
}
